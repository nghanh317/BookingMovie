spring.application.name=cgv
# -----------------------
# Database
# -----------------------
spring.datasource.url=jdbc:mysql://localhost:3306/cinema_cgv
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver
spring.datasource.username=root
spring.datasource.password=your_database_password

# -----------------------
# Hibernate
# -----------------------
# Naming entity mapping table in SQL
spring.jpa.hibernate.naming.physical-strategy=org.hibernate.boot.model.naming.PhysicalNamingStrategyStandardImpl
spring.jpa.hibernate.ddl-auto=update
# Show SQL
logging.level.org.hibernate.SQL=OFF
logging.level.org.hibernate.type.descriptor.sql.BasicBinder=OFF
spring.jpa.properties.hibernate.format_sql=true
# -----------------------
# Pagable
# -----------------------
# Default page size
spring.data.web.pageable.default-page-size=5
# parameter name
spring.data.web.pageable.page-parameter=pageNumber
spring.data.web.pageable.size-parameter=size
spring.data.web.sort.sort-parameter=sort

# -----------------------
# DateTime Format
# -----------------------
# Default page size
spring.jackson.date-format=dd-MM-yyyy HH:mm:ss
spring.mvc.format.date=dd-MM-yyyy HH:mm:ss
spring.jackson.time-zone=Asia/Ho_Chi_Minh
spring.jpa.properties.hibernate.jdbc.time_zone=Asia/Ho_Chi_Minh
# -----------------------
# swagger 2
# -----------------------
spring.mvc.pathmatch.matching-strategy=ant-path-matcher

# -----------------------
# Global Exception Handling
# -----------------------

# -----------------------
# JWT
# -----------------------
jwt.secret=your_jwt_secret
jwt.access.expiration=900000
jwt.refresh.expiration=604800000
jwt.header=Authorization
jwt.prefix=Bearer
spring.mvc.throw-exception-if-no-handler-found=true
spring.mvc.static-path-pattern=/swagger*

# Google AI API Key
google.ai.api-key=your_google_ai_api_key

#mail
spring.mail.host=smtp.gmail.com
spring.mail.port=587
spring.mail.username=your_email@gmail.com
spring.mail.password=your_email_app_password
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true

#payOs
payos.client-id=your_payos_client_id
payos.api-key=your_payos_api_key
payos.checksum-key=your_payos_checksum_key
# URL của frontend React để redirect sau thanh toán
app.frontend-url=http://localhost:5173
# Test mode: true = gửi giá ảo lên PayOS (2000đ), DB vẫn lưu giá thật
# Tắt khi deploy thật: payment.test-mode=false
payment.test-mode=true
# -----------------------

# ===================================================================
# CẤU HÌNH REDIS (SPRING BOOT 3.X)
# ===================================================================

# Thông tin kết nối cơ bản
spring.data.redis.host=localhost
spring.data.redis.port=6379
# Nếu bạn chưa đặt mật khẩu trong docker-compose, hãy để trống hoặc xóa dòng này
spring.data.redis.password=your_redis_password
# Database index (mặc định là 0, thường không cần thay đổi)
spring.data.redis.database=0

# Thời gian chờ kết nối (mili-giây)
spring.data.redis.timeout=60000

# Cấu hình Connection Pool (giúp hệ thống chịu tải tốt hơn khi nhiều user cùng đặt vé)
# Số lượng kết nối tối đa có thể mở cùng lúc
spring.data.redis.lettuce.pool.max-active=8
# Số lượng kết nối tối đa giữ ở trạng thái nghỉ
spring.data.redis.lettuce.pool.max-idle=8
# Số lượng kết nối tối thiểu giữ ở trạng thái nghỉ
spring.data.redis.lettuce.pool.min-idle=2

# Thời gian chờ lấy kết nối từ pool
spring.data.redis.lettuce.pool.max-wait=1ms
