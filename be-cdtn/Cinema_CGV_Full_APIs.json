		},
		{
			"name": "7. Tickets (Vé & Đặt vé)",
			"item": [
				{
					"name": "Lấy danh sách Vé",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/tickets?pageNumber=0&size=10",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "tickets"]
						}
					}
				},
				{
					"name": "Chi tiết Vé (ID)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/tickets/1",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "tickets", "1"]
						}
					}
				},
				{
					"name": "Đặt vé trực tuyến",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\r\n    \"accountsId\": 1,\r\n    \"slotsId\": 1,\r\n    \"discountAmount\": 0,\r\n    \"note\": \"Booking from Postman\",\r\n    \"seats\": [\r\n        { \"seatId\": 1 },\r\n        { \"seatId\": 2 }\r\n    ],\r\n    \"products\": [\r\n        { \"productId\": 1, \"quantity\": 2 }\r\n    ]\r\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/tickets",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "tickets"]
						}
					}
				},
				{
					"name": "Cập nhật Trạng thái vé",
					"request": {
						"method": "PUT",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\r\n    \"paymentStatus\": \"PAID\",\r\n    \"status\": \"CONFIRMED\"\r\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/tickets/1",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "tickets", "1"]
						}
					}
				},
				{
					"name": "Hủy/Xóa vé",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/tickets/1",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "tickets", "1"]
						}
					}
				}
			]
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{jwt_token}}",
				"type": "string"
			}
		]
	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [""]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [""]
			}
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080",
			"type": "string"
		},
		{
			"key": "jwt_token",
			"value": "",
			"type": "string"
		}
	]
}
