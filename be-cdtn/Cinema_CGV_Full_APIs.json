		{
			"name": "5. Cinemas (Rạp hát)",
			"item": [
				{
					"name": "Danh sách Rạp",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/cinemas?pageNumber=0&size=10",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "cinemas"]
						}
					}
				}
			]
		},
		{
			"name": "6. Rooms (Phòng chiếu)",
			"item": [
				{
					"name": "Danh sách Phòng",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/rooms?pageNumber=0&size=10",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "rooms"]
						}
					}
				}
