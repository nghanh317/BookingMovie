{
	"info": {
		"name": "Cinema CGV Full APIs",
		"description": "Toàn bộ danh sách các API của dự án Backend Cinema CGV dùng để test.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Khởi tạo / Auth",
			"item": [
				{
					"name": "Đăng nhập (Lấy Token)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if(jsonData.token) {",
									"    pm.collectionVariables.set(\"jwt_token\", jsonData.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\r\n    \"userName\": \"admin\",\r\n    \"passwordHash\": \"123456\"\r\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/login",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"auth",
								"login"
							]
						}
					}
				}
			]
		},
		{
			"name": "2. Accounts (Tài khoản)",
			"item": [
				{
					"name": "Lấy danh sách Account",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/accounts?pageNumber=0&size=10",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "accounts"],
							"query": [
								{"key": "pageNumber", "value": "0"},
								{"key": "size", "value": "10"}
							]
						}
					}
				},
				{
					"name": "Lấy Account theo ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/accounts/1",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "accounts", "1"]
						}
					}
				},
				{
					"name": "Thêm mới Account (Đăng ký)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\r\n    \"userName\": \"testuser\",\r\n    \"passwordHash\": \"123456\",\r\n    \"email\": \"test@gmail.com\",\r\n    \"phone\": \"0123456789\",\r\n    \"fullName\": \"Nguyen Van A\",\r\n    \"role\": \"USER\"\r\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/register",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "register"]
						}
					}
				},
				{
					"name": "Cập nhật Account",
					"request": {
						"method": "PUT",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\r\n    \"userName\": \"testuser\",\r\n    \"email\": \"testupdated@gmail.com\",\r\n    \"phone\": \"0123456789\",\r\n    \"fullName\": \"Nguyen Van A Updated\",\r\n    \"role\": \"USER\"\r\n}",
							"options": {"raw": {"language": "json"}}
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/accounts/1",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "accounts", "1"]
						}
					}
				},
				{
					"name": "Xóa Account",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/accounts/1",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "accounts", "1"]
						}
					}
				}
			]
		},
		{
			"name": "3. Movies (Bộ Phim)",
			"item": [
				{
					"name": "Danh sách Phim",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/movies?pageNumber=0&size=10",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "movies"]
						}
					}
				}
			]
		},
		{
