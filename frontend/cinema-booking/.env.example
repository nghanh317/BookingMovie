# Biến môi trường — CinemaBook Frontend
# Sao chép file này thành .env và điền giá trị thật

# ── API Backend ────────────────────────────────────────────
# URL gốc của backend API (không có dấu / ở cuối)
VITE_API_BASE_URL=http://localhost:8080/api

# ── Google OAuth ───────────────────────────────────────────
# Lấy tại: https://console.cloud.google.com → APIs & Services → Credentials
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# ── Facebook OAuth ─────────────────────────────────────────
# Lấy tại: https://developers.facebook.com → My Apps
VITE_FACEBOOK_APP_ID=your_facebook_app_id_here

# ── Payment Gateways ───────────────────────────────────────
# MoMo (lấy từ dashboard MoMo Business)
VITE_MOMO_PARTNER_CODE=your_momo_partner_code

# VNPay (lấy từ cổng thanh toán VNPay)
VITE_VNPAY_TMN_CODE=your_vnpay_tmn_code

# ── App Config ─────────────────────────────────────────────
# Tên ứng dụng (hiển thị trong title tab trình duyệt)
VITE_APP_NAME=CinemaBook
